# Optional environment for the read-only schedule publish server.
# Copy to .env locally if your deployment platform does not manage env vars.

SCHEDULE_VIEWER_USERNAME=schedule-viewer
SCHEDULE_VIEWER_PASSWORD_HASH=replace-with-python3-schedule_publish_server-py-hash-password-output
SCHEDULE_VIEWER_SECRET_KEY=replace-with-random-secret
SCHEDULE_VIEWER_COOKIE_SECURE=0
